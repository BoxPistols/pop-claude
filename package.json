{
  "name": "pop-claude",
  "version": "1.0.0",
  "description": "Claude Codeのコマンドをローカルで承認/拒否するmacOSメニューバーアプリ",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "setup": "node setup.js",
    "build": "electron-builder --mac",
    "dev": "NODE_ENV=development electron ."
  },
  "build": {
    "appId": "dev.popclaude.app",
    "productName": "pop-claude",
    "mac": {
      "icon": "icon.icns",
      "category": "public.app-category.developer-tools",
      "target": ["dmg"],
      "extendInfo": { "LSUIElement": true }
    },
    "directories": { "output": "dist" },
    "files": ["main.js", "popup.html", "history.html", "hook.js", "setup.js", "tray-iconTemplate*.png"]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "license": "MIT"
}
